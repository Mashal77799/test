<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>لوحة تحكم سيرفر Roblox</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-main: #060a0f;
    --bg-card: #0d1520;
    --bg-card2: #0a1019;
    --bg-panel: #101c2a;
    --accent: #00e5ff;
    --accent2: #00ff9d;
    --accent3: #ff6b35;
    --online: #00ff88;
    --offline: #ff3355;
    --warn: #ffcc00;
    --text: #c8e0f4;
    --text-dim: #5a7a94;
    --border: rgba(0,229,255,0.12);
    --border2: rgba(0,229,255,0.06);
    --glow: 0 0 20px rgba(0,229,255,0.3);
    --glow-green: 0 0 20px rgba(0,255,136,0.4);
    --glow-red: 0 0 20px rgba(255,51,85,0.4);
    --font-ar: 'Tajawal', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg-main);
    color: var(--text);
    font-family: var(--font-ar);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── BACKGROUND GRID ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -50%;
    right: -20%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0,229,255,0.05) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
    animation: pulse-bg 6s ease-in-out infinite alternate;
  }

  @keyframes pulse-bg {
    from { opacity: 0.5; transform: scale(1); }
    to   { opacity: 1;   transform: scale(1.15); }
  }

  /* ─── HEADER ─── */
  header {
    position: relative;
    z-index: 10;
    background: linear-gradient(180deg, rgba(0,229,255,0.08) 0%, transparent 100%);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    backdrop-filter: blur(12px);
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: var(--glow);
    animation: logo-pulse 3s ease-in-out infinite;
  }

  @keyframes logo-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(0,229,255,0.3); }
    50%       { box-shadow: 0 0 40px rgba(0,229,255,0.7); }
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-title {
    font-size: 20px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 1px;
    line-height: 1.1;
  }

  .logo-sub {
    font-size: 11px;
    color: var(--accent);
    font-family: var(--font-mono);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    background: rgba(0,255,136,0.1);
    border: 1px solid rgba(0,255,136,0.3);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--online);
    letter-spacing: 1px;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: var(--online);
    border-radius: 50%;
    animation: blink 1s ease-in-out infinite;
    box-shadow: 0 0 8px var(--online);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .server-time {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  /* ─── ANNOUNCEMENT BAR ─── */
  .announce-bar {
    position: relative;
    z-index: 9;
    background: linear-gradient(90deg, #1a0a00, rgba(255,107,53,0.15), #1a0a00);
    border-bottom: 1px solid rgba(255,107,53,0.3);
    padding: 9px 0;
    overflow: hidden;
  }

  .announce-track {
    display: flex;
    gap: 80px;
    animation: scroll-announce 35s linear infinite;
    white-space: nowrap;
  }

  .announce-track span {
    font-size: 12px;
    color: var(--accent3);
    font-family: var(--font-mono);
    letter-spacing: 1px;
  }

  .announce-track span::before {
    content: '⚡ ';
  }

  @keyframes scroll-announce {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── LAYOUT ─── */
  .main-wrapper {
    position: relative;
    z-index: 1;
    max-width: 1600px;
    margin: 0 auto;
    padding: 28px 24px 60px;
    display: grid;
    gap: 24px;
  }

  /* ─── TOP STATS ROW ─── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 14px;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
    cursor: default;
  }

  .stat-card:hover {
    transform: translateY(-3px);
    border-color: rgba(0,229,255,0.3);
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent-grad, linear-gradient(90deg, var(--accent), var(--accent2)));
    border-radius: 16px 16px 0 0;
  }

  .stat-card.red::before   { background: linear-gradient(90deg, var(--offline), #ff8899); }
  .stat-card.green::before { background: linear-gradient(90deg, var(--online), #00ffcc); }
  .stat-card.warn::before  { background: linear-gradient(90deg, var(--warn), #ffaa00); }
  .stat-card.purple::before { background: linear-gradient(90deg, #a855f7, #7c3aed); }
  .stat-card.orange::before { background: linear-gradient(90deg, var(--accent3), #ffaa00); }

  .stat-icon {
    font-size: 22px;
    margin-bottom: 8px;
    display: block;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    font-family: var(--font-mono);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .stat-change {
    position: absolute;
    top: 16px;
    left: 16px;
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 2px 8px;
    border-radius: 10px;
  }

  .stat-change.up   { background: rgba(0,255,136,0.15); color: var(--online); }
  .stat-change.down { background: rgba(255,51,85,0.15);  color: var(--offline); }

  /* ─── CONTENT GRID ─── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    align-items: start;
  }

  .left-col { display: flex; flex-direction: column; gap: 24px; }
  .right-col { display: flex; flex-direction: column; gap: 24px; }

  /* ─── PANEL ─── */
  .panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border2);
    background: rgba(0,229,255,0.03);
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.5px;
  }

  .panel-title-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .panel-title-icon.cyan   { background: rgba(0,229,255,0.15); }
  .panel-title-icon.green  { background: rgba(0,255,136,0.15); }
  .panel-title-icon.red    { background: rgba(255,51,85,0.15); }
  .panel-title-icon.orange { background: rgba(255,107,53,0.15); }
  .panel-title-icon.purple { background: rgba(168,85,247,0.15); }

  .panel-badge {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid;
    letter-spacing: 1px;
  }

  .panel-badge.online  { color: var(--online);  border-color: rgba(0,255,136,0.4);  background: rgba(0,255,136,0.08); }
  .panel-badge.offline { color: var(--offline); border-color: rgba(255,51,85,0.4);  background: rgba(255,51,85,0.08); }
  .panel-badge.neutral { color: var(--accent);  border-color: rgba(0,229,255,0.4);  background: rgba(0,229,255,0.08); }

  /* ─── SERVER INFO CARD ─── */
  .server-hero {
    background: linear-gradient(135deg, var(--bg-card) 0%, #0d2035 100%);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    position: relative;
    overflow: hidden;
  }

  .server-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top right, rgba(0,229,255,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .server-banner {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #001a2e, #002a45, #001525);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .server-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(0,229,255,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, rgba(0,255,136,0.10) 0%, transparent 50%);
  }

  .server-banner-text {
    font-size: 42px;
    font-weight: 900;
    color: transparent;
    background: linear-gradient(135deg, var(--accent), var(--accent2), var(--accent));
    background-clip: text;
    -webkit-background-clip: text;
    letter-spacing: 4px;
    font-family: var(--font-mono);
    text-shadow: none;
    position: relative;
    z-index: 1;
  }

  .server-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 20px;
  }

  .meta-item {
    background: var(--bg-card2);
    border: 1px solid var(--border2);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
  }

  .meta-item-val {
    font-size: 20px;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 4px;
  }

  .meta-item-key {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ─── PLAYERS TABLE ─── */
  .players-table {
    width: 100%;
    border-collapse: collapse;
  }

  .players-table thead th {
    padding: 12px 20px;
    text-align: right;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-bottom: 1px solid var(--border2);
    background: rgba(0,0,0,0.2);
  }

  .players-table tbody tr {
    border-bottom: 1px solid var(--border2);
    transition: background 0.15s;
    cursor: pointer;
  }

  .players-table tbody tr:hover { background: rgba(0,229,255,0.04); }
  .players-table tbody tr:last-child { border-bottom: none; }

  .players-table tbody td {
    padding: 13px 20px;
    font-size: 13px;
    vertical-align: middle;
  }

  .player-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .player-avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
    border: 2px solid transparent;
  }

  .player-avatar.online-av  { border-color: var(--online);  box-shadow: 0 0 10px rgba(0,255,136,0.3); }
  .player-avatar.offline-av { border-color: rgba(255,51,85,0.4); filter: grayscale(50%); }

  .player-name {
    font-weight: 600;
    color: #fff;
    font-size: 14px;
  }

  .player-id {
    font-size: 11px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .status-dot {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-family: var(--font-mono);
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
  }

  .status-dot.on  {
    color: var(--online);
    background: rgba(0,255,136,0.1);
    border: 1px solid rgba(0,255,136,0.3);
  }

  .status-dot.off {
    color: var(--offline);
    background: rgba(255,51,85,0.1);
    border: 1px solid rgba(255,51,85,0.3);
  }

  .status-dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    display: inline-block;
  }

  .status-dot.on::before { animation: blink 1.2s ease-in-out infinite; box-shadow: 0 0 6px currentColor; }

  .rank-badge {
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 10px;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .rank-owner  { background: linear-gradient(90deg,#ff6b35,#ffaa00); color: #000; }
  .rank-admin  { background: linear-gradient(90deg,#a855f7,#7c3aed); color: #fff; }
  .rank-mod    { background: linear-gradient(90deg,#00e5ff,#00a0ff); color: #000; }
  .rank-vip    { background: linear-gradient(90deg,#ffd700,#ffaa00); color: #000; }
  .rank-player { background: rgba(100,120,140,0.3); color: var(--text-dim); }

  .playtime-bar {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bar-bg {
    width: 80px;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    transition: width 1s ease;
  }

  .bar-val {
    font-size: 11px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  /* ─── SEARCH & FILTER ─── */
  .table-toolbar {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border2);
    flex-wrap: wrap;
  }

  .search-box {
    flex: 1;
    min-width: 180px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-card2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 8px 14px;
    transition: border-color 0.2s;
  }

  .search-box:focus-within { border-color: rgba(0,229,255,0.5); }

  .search-box input {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-ar);
    font-size: 13px;
    width: 100%;
    direction: rtl;
  }

  .search-box input::placeholder { color: var(--text-dim); }

  .filter-btn {
    padding: 8px 16px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-card2);
    color: var(--text-dim);
    font-family: var(--font-ar);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,229,255,0.08);
  }

  .filter-btn.green.active { border-color: var(--online); color: var(--online); background: rgba(0,255,136,0.08); }
  .filter-btn.red.active   { border-color: var(--offline); color: var(--offline); background: rgba(255,51,85,0.08); }

  /* ─── MINI PLAYER LIST (right panel) ─── */
  .mini-player {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border2);
    transition: background 0.15s;
    cursor: pointer;
  }

  .mini-player:hover  { background: rgba(0,229,255,0.04); }
  .mini-player:last-child { border-bottom: none; }

  .mini-avatar {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    position: relative;
  }

  .mini-status-ring {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--bg-card);
  }

  .mini-status-ring.on  { background: var(--online);  box-shadow: 0 0 6px var(--online); }
  .mini-status-ring.off { background: var(--offline); }

  .mini-info { flex: 1; min-width: 0; }

  .mini-name {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mini-sub {
    font-size: 11px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  /* ─── ACTIVITY FEED ─── */
  .feed-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border2);
    position: relative;
  }

  .feed-item:last-child { border-bottom: none; }

  .feed-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feed-icon.join   { background: rgba(0,255,136,0.12); }
  .feed-icon.leave  { background: rgba(255,51,85,0.12); }
  .feed-icon.ban    { background: rgba(255,107,53,0.12); }
  .feed-icon.chat   { background: rgba(0,229,255,0.12); }
  .feed-icon.event  { background: rgba(168,85,247,0.12); }
  .feed-icon.reward { background: rgba(255,204,0,0.12); }

  .feed-content { flex: 1; }

  .feed-text {
    font-size: 12.5px;
    color: var(--text);
    line-height: 1.5;
  }

  .feed-text strong { color: #fff; font-weight: 700; }
  .feed-text .hl    { color: var(--accent); }

  .feed-time {
    font-size: 10px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    margin-top: 3px;
  }

  /* ─── PERFORMANCE CHART ─── */
  .chart-area {
    padding: 20px;
    position: relative;
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 11px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .chart-svg-wrap {
    width: 100%;
    height: 140px;
    position: relative;
  }

  .chart-svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .chart-grid line {
    stroke: rgba(0,229,255,0.06);
    stroke-width: 1;
  }

  .chart-path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 6px rgba(0,229,255,0.6));
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw-line 2s ease forwards 0.5s;
  }

  .chart-path2 {
    fill: none;
    stroke: var(--online);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 6px rgba(0,255,136,0.5));
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw-line 2s ease forwards 0.8s;
  }

  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }

  .chart-fill {
    opacity: 0.08;
    animation: fade-fill 2s ease forwards 0.5s;
    fill: var(--accent);
  }

  .chart-fill2 {
    opacity: 0.06;
    animation: fade-fill 2s ease forwards 0.8s;
    fill: var(--online);
  }

  @keyframes fade-fill {
    from { opacity: 0; }
    to   { opacity: 0.08; }
  }

  .chart-legend {
    display: flex;
    gap: 20px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border2);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    color: var(--text-dim);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  /* ─── SERVER RULES ─── */
  .rules-list {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .rule-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 14px;
    background: var(--bg-card2);
    border: 1px solid var(--border2);
    border-radius: 10px;
    transition: border-color 0.2s;
  }

  .rule-item:hover { border-color: rgba(0,229,255,0.2); }

  .rule-num {
    min-width: 26px;
    height: 26px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
    font-weight: 900;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .rule-text {
    font-size: 12.5px;
    color: var(--text);
    line-height: 1.5;
  }

  /* ─── ANNOUNCEMENTS ─── */
  .announce-list {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .announce-card {
    padding: 14px;
    border-radius: 12px;
    border: 1px solid;
    position: relative;
    overflow: hidden;
  }

  .announce-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 3px;
    background: currentColor;
    opacity: 0.6;
    border-radius: 0 12px 12px 0;
  }

  .announce-card.info  { border-color: rgba(0,229,255,0.25);  background: rgba(0,229,255,0.05);  color: var(--accent); }
  .announce-card.warn  { border-color: rgba(255,204,0,0.25);  background: rgba(255,204,0,0.05);  color: var(--warn); }
  .announce-card.event { border-color: rgba(168,85,247,0.25); background: rgba(168,85,247,0.05); color: #a855f7; }

  .announce-card-title {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 5px;
    color: currentColor;
  }

  .announce-card-body {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
  }

  .announce-card-date {
    font-size: 10px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    margin-top: 6px;
  }

  /* ─── QUICK ACTIONS ─── */
  .quick-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 16px 20px;
  }

  .action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-card2);
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .action-btn:hover {
    border-color: var(--accent);
    background: rgba(0,229,255,0.07);
    transform: translateY(-2px);
  }

  .action-btn span:first-child { font-size: 22px; }

  .action-btn span:last-child {
    font-size: 11px;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 0.5px;
  }

  /* ─── UPTIME BAR ─── */
  .uptime-section {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .uptime-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .uptime-label-row {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-dim);
  }

  .uptime-label-row span:last-child {
    font-family: var(--font-mono);
    color: var(--text);
  }

  .uptime-track {
    height: 8px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }

  .uptime-fill {
    height: 100%;
    border-radius: 8px;
    position: relative;
    transition: width 1.5s ease;
  }

  .uptime-fill.cyan   { background: linear-gradient(90deg, var(--accent), var(--accent2)); box-shadow: 0 0 10px rgba(0,229,255,0.4); }
  .uptime-fill.green  { background: linear-gradient(90deg, var(--online), #00ccff);        box-shadow: 0 0 10px rgba(0,255,136,0.4); }
  .uptime-fill.orange { background: linear-gradient(90deg, var(--accent3), var(--warn));   box-shadow: 0 0 10px rgba(255,107,53,0.4); }
  .uptime-fill.purple { background: linear-gradient(90deg, #a855f7, #7c3aed);              box-shadow: 0 0 10px rgba(168,85,247,0.4); }

  /* ─── LEADERBOARD ─── */
  .leaderboard-list { padding: 8px 0; }

  .lb-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 20px;
    border-bottom: 1px solid var(--border2);
    transition: background 0.15s;
    cursor: pointer;
  }

  .lb-item:last-child  { border-bottom: none; }
  .lb-item:hover { background: rgba(0,229,255,0.04); }

  .lb-rank {
    width: 24px;
    font-size: 13px;
    font-weight: 900;
    font-family: var(--font-mono);
    text-align: center;
    flex-shrink: 0;
  }

  .lb-rank.gold   { color: #ffd700; }
  .lb-rank.silver { color: #c0c8d0; }
  .lb-rank.bronze { color: #cd7f32; }
  .lb-rank.other  { color: var(--text-dim); }

  .lb-avatar {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .lb-name {
    flex: 1;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .lb-score {
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 700;
  }

  /* ─── CHAT LOG ─── */
  .chat-list { padding: 0; max-height: 300px; overflow-y: auto; }

  .chat-list::-webkit-scrollbar { width: 4px; }
  .chat-list::-webkit-scrollbar-track { background: transparent; }
  .chat-list::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 4px; }

  .chat-item {
    padding: 10px 18px;
    border-bottom: 1px solid var(--border2);
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .chat-item:last-child { border-bottom: none; }

  .chat-avatar {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(0,229,255,0.1);
    margin-top: 1px;
  }

  .chat-content { flex: 1; }

  .chat-name {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 3px;
  }

  .chat-msg {
    font-size: 12px;
    color: var(--text);
    line-height: 1.4;
  }

  .chat-time {
    font-size: 10px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    white-space: nowrap;
    margin-top: 2px;
  }

  /* ─── SERVER REGIONS ─── */
  .regions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 16px 20px;
  }

  .region-card {
    background: var(--bg-card2);
    border: 1px solid var(--border2);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
    transition: all 0.2s;
    cursor: default;
  }

  .region-card:hover { border-color: rgba(0,229,255,0.25); }

  .region-flag { font-size: 24px; margin-bottom: 6px; }

  .region-name {
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 3px;
  }

  .region-ping {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--online);
  }

  .region-ping.mid  { color: var(--warn); }
  .region-ping.high { color: var(--offline); }

  /* ─── PAGINATION ─── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-top: 1px solid var(--border2);
  }

  .page-info {
    font-size: 12px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .page-btns {
    display: flex;
    gap: 6px;
  }

  .page-btn {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-card2);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-btn:hover, .page-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,229,255,0.08);
  }

  /* ─── MODAL ─── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 20px;
    width: 520px;
    max-width: 90vw;
    overflow: hidden;
    transform: scale(0.95);
    transition: transform 0.2s;
  }

  .modal-overlay.open .modal { transform: scale(1); }

  .modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0,229,255,0.04);
  }

  .modal-title {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .modal-close {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255,51,85,0.15);
    border: 1px solid rgba(255,51,85,0.3);
    color: var(--offline);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }

  .modal-close:hover { background: rgba(255,51,85,0.3); }

  .modal-body { padding: 24px; }

  .modal-player-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .modal-avatar {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    border: 2px solid var(--accent);
    box-shadow: var(--glow);
  }

  .modal-player-name {
    font-size: 22px;
    font-weight: 900;
    color: #fff;
    margin-bottom: 4px;
  }

  .modal-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }

  .modal-stat {
    background: var(--bg-card2);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }

  .modal-stat-val {
    font-size: 18px;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 3px;
  }

  .modal-stat-key { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

  .modal-actions-row {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  .modal-action {
    flex: 1;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid;
    font-family: var(--font-ar);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }

  .modal-action.kick  { border-color: rgba(255,204,0,0.4);  background: rgba(255,204,0,0.1);  color: var(--warn); }
  .modal-action.ban   { border-color: rgba(255,51,85,0.4);  background: rgba(255,51,85,0.1);  color: var(--offline); }
  .modal-action.msg   { border-color: rgba(0,229,255,0.4);  background: rgba(0,229,255,0.1);  color: var(--accent); }
  .modal-action.tp    { border-color: rgba(168,85,247,0.4); background: rgba(168,85,247,0.1); color: #a855f7; }

  .modal-action:hover { opacity: 0.8; transform: translateY(-1px); }

  /* ─── TABS ─── */
  .tab-bar {
    display: flex;
    gap: 2px;
    padding: 12px 20px 0;
    border-bottom: 1px solid var(--border2);
  }

  .tab {
    padding: 8px 16px;
    border-radius: 10px 10px 0 0;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.15s;
    border: 1px solid transparent;
    border-bottom: none;
    letter-spacing: 0.5px;
  }

  .tab:hover { color: var(--text); }

  .tab.active {
    color: var(--accent);
    background: rgba(0,229,255,0.06);
    border-color: var(--border);
    border-bottom-color: var(--bg-card);
  }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ─── FOOTER ─── */
  footer {
    position: relative;
    z-index: 5;
    border-top: 1px solid var(--border);
    background: var(--bg-card2);
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 12px;
    color: var(--text-dim);
  }

  .footer-left strong { color: var(--accent); }

  .footer-right {
    display: flex;
    gap: 20px;
  }

  .footer-link {
    font-size: 12px;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s;
    cursor: pointer;
  }

  .footer-link:hover { color: var(--accent); }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-main); }
  ::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 6px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(0,229,255,0.4); }

  /* ─── TOOLTIP ─── */
  [data-tip] { position: relative; }

  [data-tip]::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a2a3a;
    color: #fff;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    border: 1px solid var(--border);
    font-family: var(--font-ar);
    z-index: 99;
  }

  [data-tip]:hover::after { opacity: 1; }

  /* ─── NOTIFICATIONS ─── */
  .notif-stack {
    position: fixed;
    bottom: 24px;
    left: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 200;
  }

  .notif {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 280px;
    max-width: 360px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    animation: slide-in 0.3s ease;
    transition: opacity 0.3s, transform 0.3s;
  }

  @keyframes slide-in {
    from { transform: translateX(-20px); opacity: 0; }
    to   { transform: translateX(0);     opacity: 1; }
  }

  .notif.hide { opacity: 0; transform: translateX(-20px); }

  .notif-icon { font-size: 20px; }

  .notif-text { flex: 1; }

  .notif-title {
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .notif-sub { font-size: 11px; color: var(--text-dim); }

  .notif-close {
    font-size: 16px;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.15s;
    padding: 2px;
    background: none;
    border: none;
  }

  .notif-close:hover { color: #fff; }

  /* ─── PING INDICATOR ─── */
  .ping-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ping-bars {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 14px;
  }

  .ping-bar {
    width: 4px;
    background: var(--online);
    border-radius: 2px;
    opacity: 0.3;
    transition: opacity 0.3s;
  }

  .ping-bar.active { opacity: 1; }

  .ping-bar:nth-child(1) { height: 4px; }
  .ping-bar:nth-child(2) { height: 7px; }
  .ping-bar:nth-child(3) { height: 10px; }
  .ping-bar:nth-child(4) { height: 14px; }

  .ping-val {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--online);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1200px) {
    .stats-row { grid-template-columns: repeat(3, 1fr); }
    .content-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 700px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    header { padding: 0 16px; }
    .main-wrapper { padding: 16px 12px 40px; }
  }

  /* ─── ANIMATIONS ON LOAD ─── */
  .fade-up {
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up-anim 0.5s ease forwards;
  }

  @keyframes fade-up-anim {
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-up:nth-child(1)  { animation-delay: 0.05s; }
  .fade-up:nth-child(2)  { animation-delay: 0.10s; }
  .fade-up:nth-child(3)  { animation-delay: 0.15s; }
  .fade-up:nth-child(4)  { animation-delay: 0.20s; }
  .fade-up:nth-child(5)  { animation-delay: 0.25s; }
  .fade-up:nth-child(6)  { animation-delay: 0.30s; }

  .counter { display: inline-block; }

  /* ─── MISC ─── */
  .divider { height: 1px; background: var(--border2); margin: 0 20px; }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .tag.vip    { background: rgba(255,215,0,0.15);  color: #ffd700; }
  .tag.new    { background: rgba(0,255,136,0.15);  color: var(--online); }
  .tag.banned { background: rgba(255,51,85,0.15);  color: var(--offline); }
  .tag.boost  { background: rgba(168,85,247,0.15); color: #a855f7; }

  .empty-state {
    text-align: center;
    padding: 30px;
    color: var(--text-dim);
    font-size: 13px;
    display: none;
  }

  .empty-state .es-icon { font-size: 36px; margin-bottom: 10px; }

  /* ─── SERVER STATUS OVERVIEW ─── */
  .status-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding: 16px 20px;
  }

  .status-item {
    text-align: center;
    padding: 16px;
    background: var(--bg-card2);
    border: 1px solid var(--border2);
    border-radius: 12px;
  }

  .status-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin: 0 auto 10px;
  }

  .status-item-val {
    font-size: 16px;
    font-weight: 800;
    font-family: var(--font-mono);
    color: #fff;
    margin-bottom: 3px;
  }

  .status-item-key {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
</head>
<body>

<!-- ─── HEADER ─── -->
<header>
  <div class="header-logo">
    <div class="logo-icon">🎮</div>
    <div class="logo-text">
      <div class="logo-title">HorizonRP</div>
      <div class="logo-sub">ROBLOX ROLEPLAY SERVER</div>
    </div>
  </div>
  <div class="header-right">
    <div class="ping-wrap" id="pingDisplay" data-tip="زمن الاستجابة">
      <div class="ping-bars">
        <div class="ping-bar active"></div>
        <div class="ping-bar active"></div>
        <div class="ping-bar active"></div>
        <div class="ping-bar active"></div>
      </div>
      <span class="ping-val">24ms</span>
    </div>
    <div class="live-badge">
      <div class="live-dot"></div>
