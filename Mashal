function getFilteredPlayers() {
  const q = document.getElementById('searchInput').value.trim().toLowerCase();
  return allPlayers.filter(p => {
    const matchQ = !q || p.name.toLowerCase().includes(q) || p.region.includes(q);
    const matchF =
      currentFilter === 'all'   ? true :
      currentFilter === 'on'    ? p.status==='on' :
      currentFilter === 'off'   ? p.status==='off' :
      currentFilter === 'admin' ? ['owner','admin','mod'].includes(p.rank) :
      currentFilter === 'vip'   ? p.rank==='vip' : true;
    return matchQ && matchF;
  });
}

function renderTable() {
  const filtered = getFilteredPlayers();
