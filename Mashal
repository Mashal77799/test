      <td>
        <div class="playtime-bar">
          <div class="bar-bg"><div class="bar-fill" style="width:${barW}%"></div></div>
          <span class="bar-val">${p.hours}س</span>
        </div>
      </td>
      <td style="font-family:var(--font-mono);color:var(--accent);font-size:13px;font-weight:700;">${p.score.toLocaleString()}</td>
      <td style="font-size:11px;color:var(--text-dim);">${p.lastActive}</td>
    `;
    tr.onclick = () => openModal(p);
