  const renderChatList = (container, src) => {
    container.innerHTML = '';
    src.forEach(item => {
      const div = document.createElement('div');
      div.className = 'chat-item';
      div.innerHTML = `
        <div class="chat-avatar" style="background:${rankBg(item.rank)}">${item.avatar}</div>
        <div class="chat-content">
          <div class="chat-name" style="color:${rankColor(item.rank)}">${item.name} <span class="rank-badge rank-${item.rank}" style="font-size:9px">${RANK_LABELS[item.rank]}</span></div>
          <div class="chat-msg">${item.msg}</div>
          <div class="chat-time">${item.time}</div>
        </div>
      `;
      container.appendChild(div);
    });
  };

  const allMsgs = CHAT_MSGS.map((msg,i) => {
    const p = allPlayers[Math.floor(Math.random()*allPlayers.length)];
    return { ...p, msg, time: `${String(Math.floor(Math.random()*24)).padStart(2,'0')}:${String(Math.floor(Math.random()*60)).padStart(2,'0')}` };
  });

  const adminMsgs = allMsgs.filter(m=>['owner','admin','mod'].includes(m.rank)).slice(0,8);
  const sysMsgs = [
    { avatar:'⚙️', rank:'owner', name:'النظام', msg:'تم تطبيق تحديث 4.7.2 بنجاح', time:'00:01' },
    { avatar:'🔒', rank:'owner', name:'الأمان', msg:'تم اكتشاف محاولة اختراق وحجبها', time:'02:30' },
    { avatar:'📡', rank:'owner', name:'الشبكة', msg:'اتصال CDN مستقر — كل الأنظمة تعمل', time:'06:00' },
    { avatar:'💾', rank:'owner', name:'الذاكرة', msg:'نسخة احتياطية ناجحة لقاعدة البيانات', time:'09:00' },
    { avatar:'⚡', rank:'owner', name:'الأداء', msg:'ذروة التحميل — 380 لاعب متزامن', time:'20:45' },
  ];

  renderChatList(document.getElementById('chatList'), allMsgs.slice(0,20));
  renderChatList(document.getElementById('chatAdminList'), adminMsgs);
  renderChatList(document.getElementById('chatSysList'), sysMsgs);

  document.getElementById('chatCount').textContent = `${allMsgs.length} رسالة`;
}

function rankColor(r) {
  return {owner:'#ff6b35',admin:'#a855f7',mod:' var(--accent)',vip:'#ffd700',player:'#fff'}[r]||'#fff';
}

/* ━━━━━━━━━━━━━━━━━━━━ LEADERBOARD ━━━━━━━━━━━━━━━━━━━━ */
function renderLeaderboard() {
  const top = [...allPlayers].sort((a,b)=>b.score-a.score).slice(0,10);
  const rankClass = i => ['gold','silver','bronze','other','other','other','other','other','other','other'][i];
  const rankNum = i => ['🥇','🥈','🥉',4,5,6,7,8,9,10][i];
  const container = document.getElementById('leaderboard');
  container.innerHTML = '';
  top.forEach((p,i) => {
    const div = document.createElement('div');
    div.className = 'lb-item';
    div.innerHTML = `
      <div class="lb-rank ${rankClass(i)}">${rankNum(i)}</div>
      <div class="lb-avatar" style="background:${rankBg(p.rank)}">${p.avatar}</div>
      <div class="lb-name">${p.name} <span class="rank-badge rank-${p.rank}" style="font-size:9px">${RANK_LABELS[p.rank]}</span></div>
      <div class="lb-score">${p.score.toLocaleString()}</div>
    `;
    div.onclick = () => openModal(p);
    container.appendChild(div);
  });
}

/* ━━━━━━━━━━━━━━━━━━━━ MODAL ━━━━━━━━━━━━━━━━━━━━ */
function openModal(p) {
  document.getElementById('modalPlayerName').textContent = p.name;
  document.getElementById('modalName').textContent = p.name;
  document.getElementById('modalAvatar').textContent = p.avatar;
  document.getElementById('modalAvatar').style.background = rankBg(p.rank);
  const statusEl = document.getElementById('modalStatus');
  statusEl.className = 'status-dot ' + p.status;
  statusEl.textContent = p.status==='on' ? 'متصل' : 'غير متصل';
  document.getElementById('modalRankDisplay').innerHTML = `<span class="rank-badge rank-${p.rank}">${RANK_LABELS[p.rank]}</span>`;
  document.getElementById('mStatScore').textContent = p.score.toLocaleString();
  document.getElementById('mStatTime').textContent = p.hours + ' ساعة';
  document.getElementById('mStatKills').textContent = p.kills;
  document.getElementById('mStatRegion').textContent = p.region;
  document.getElementById('mStatJoined').textContent = p.joined;
  document.getElementById('mStatWarns').textContent = p.warns + ' ⚠️';
  document.getElementById('modalExtra').textContent = `ID: #${String(p.id).padStart(4,'0')} | IP: ${p.ip} | آخر نشاط: ${p.lastActive}`;
  document.getElementById('playerModal').classList.add('open');
}

function closeModal() {
  document.getElementById('playerModal').classList.remove('open');
}

/* ━━━━━━━━━━━━━━━━━━━━ TABS ━━━━━━━━━━━━━━━━━━━━ */
function showTab(id, btn) {
  btn.closest('.panel').querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  btn.closest('.panel').querySelectorAll('.tab').forEach(el=>el.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

/* ━━━━━━━━━━━━━━━━━━━━ NOTIFICATIONS ━━━━━━━━━━━━━━━━━━━━ */
function showNotif(icon, title, sub) {
  const stack = document.getElementById('notifStack');
  const div = document.createElement('div');
  div.className = 'notif';
  div.innerHTML = `
    <span class="notif-icon">${icon}</span>
    <div class="notif-text">
      <div class="notif-title">${title}</div>
      <div class="notif-sub">${sub}</div>
    </div>
    <button class="notif-close" onclick="removeNotif(this.parentElement)">✕</button>
  `;
  stack.appendChild(div);
  setTimeout(()=>removeNotif(div), 4000);
}

function removeNotif(el) {
  if (!el || !el.parentElement) return;
  el.classList.add('hide');
  setTimeout(()=>el.remove(), 300);
}

/* ━━━━━━━━━━━━━━━━━━━━ CLOCK ━━━━━━━━━━━━━━━━━━━━ */
function updateClock() {
  const now = new Date();
  document.getElementById('clockDisplay').textContent =
    `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;
}

/* ━━━━━━━━━━━━━━━━━━━━ LIVE UPDATES ━━━━━━━━━━━━━━━━━━━━ */
let tickCount = 0;
function liveUpdate() {
  tickCount++;
  // Randomly change a player's status
  if (tickCount % 8 === 0) {
    const idx = Math.floor(Math.random()*allPlayers.length);
    const p = allPlayers[idx];
    // Don't toggle owner or main admins
    if (p.rank !== 'owner') {
      const wasOn = p.status === 'on';
      p.status = wasOn ? 'off' : 'on';
      p.lastActive = 'الآن';
      // Show notification
      showNotif(wasOn?'🔴':'🟢', wasOn?'غادر السيرفر':'انضم للسيرفر', p.name);
    }
  }

  // Update random player's score
  if (tickCount % 5 === 0) {
    const idx = Math.floor(Math.random()*allPlayers.length);
    allPlayers[idx].score += Math.floor(Math.random()*50)+10;
  }

  updateStats();
  renderMiniLists();

  // Refresh table if page 1
  if (currentPage === 1) renderTable();

  // Update leaderboard
  if (tickCount % 4 === 0) renderLeaderboard();
}

/* ━━━━━━━━━━━━━━━━━━━━ INIT ━━━━━━━━━━━━━━━━━━━━ */
window.addEventListener('DOMContentLoaded', () => {
  allPlayers = generatePlayers();
  updateStats();
  renderTable();
  renderMiniLists();
  renderChart();
  generateFeed();
  generateChat();
  renderLeaderboard();
  updateClock();

  setInterval(updateClock, 1000);
  setInterval(liveUpdate, 3000);

  // Ping simulation
  setInterval(() => {
    const ping = Math.floor(Math.random()*30)+15;
    const el = document.querySelector('.ping-val');
    if(el) el.textContent = ping+'ms';
    const bars = document.querySelectorAll('.ping-bar');
    const signal = ping < 30 ? 4 : ping < 60 ? 3 : ping < 100 ? 2 : 1;
    bars.forEach((b,i) => b.classList.toggle('active', i < signal));
    el.style.color = signal===4?'var(--online)':signal===3?'var(--warn)':'var(--offline)';
  }, 2500);

  // Random activity notifications
  setTimeout(()=>{
    const msgs = [
      ['🏆','إيفنت جديد','سباق الليلة الساعة 9!'],
      ['👤','لاعب جديد','انضم xGhost_Pro للسيرفر'],
      ['⚠️','تحذير','تم رصد مخالفة في المنطقة 3'],
      ['🎁','مكافأة','ShadowX حصل على 500 كريدت'],
    ];
    let i=0;
    setInterval(()=>{
      const m = msgs[i % msgs.length];
      showNotif(m[0],m[1],m[2]);
      i++;
    }, 12000);
  }, 5000);
});
</script>
