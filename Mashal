  const offCount = allPlayers.filter(p=>p.status==='off').length;
  animateCount('onlineCount', onCount);
  animateCount('offlineCount', offCount);
  animateCount('totalCount', allPlayers.length);
  animateCount('eventCount', 47);
  animateCount('banCount', 12);
  document.getElementById('heroOnline').textContent = onCount;
  document.getElementById('onlineBadge').textContent  = `● ${onCount} متصل`;
  document.getElementById('offlineBadge').textContent = `● ${offCount} غير متصل`;
