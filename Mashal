function animateCount(id, target) {
  const el = document.getElementById(id);
  if (!el) return;
  let current = 0;
  const step = Math.ceil(target/60);
  const timer = setInterval(()=>{
    current = Math.min(current+step, target);
    el.textContent = current.toLocaleString();
    if (current >= target) clearInterval(timer);
  }, 20);
}

/* ━━━━━━━━━━━━━━━━━━━━ CHART ━━━━━━━━━━━━━━━━━━━━ */
function renderChart() {
  const hours = 24;
  const data1 = [], data2 = [];
  let base1 = 180, base2 = 45;
  for (let i=0; i<hours; i++) {
    base1 = Math.max(50, Math.min(400, base1 + (Math.random()-0.48)*40));
    base2 = Math.max(5,  Math.min(80,  base2 + (Math.random()-0.5)*12));
    data1.push(Math.round(base1));
    data2.push(Math.round(base2));
  }

  const W=800, H=140, pad=10;
  const max1 = Math.max(...data1)*1.1;
  const max2 = Math.max(...data2)*1.1;

  const ptX = (i) => pad + (i/(hours-1))*(W-pad*2);
  const ptY1 = (v) => H - pad - (v/max1)*(H-pad*2);
  const ptY2 = (v) => H - pad - (v/max2)*(H-pad*2);

  const path1 = data1.map((v,i)=>`${i===0?'M':'L'}${ptX(i)},${ptY1(v)}`).join(' ');
  const path2 = data2.map((v,i)=>`${i===0?'M':'L'}${ptX(i)},${ptY2(v)}`).join(' ');
  const fill1 = path1 + ` L${ptX(hours-1)},${H} L${ptX(0)},${H} Z`;
  const fill2 = path2 + ` L${ptX(hours-1)},${H} L${ptX(0)},${H} Z`;

  document.getElementById('chartLine').setAttribute('d', path1);
  document.getElementById('chartLine2').setAttribute('d', path2);
  document.getElementById('chartFill').setAttribute('d', fill1);
  document.getElementById('chartFill2').setAttribute('d', fill2);

  // Grid
  const grid = document.getElementById('chartGrid');
  grid.innerHTML = '';
  for (let g=0; g<=4; g++) {
    const y = pad + (g/4)*(H-pad*2);
    const ln = document.createElementNS('http://www.w3.org/2000/svg','line');
    ln.setAttribute('x1',pad); ln.setAttribute('x2',W-pad);
    ln.setAttribute('y1',y); ln.setAttribute('y2',y);
    grid.appendChild(ln);
  }

  // Labels
  const labelWrap = document.getElementById('chartLabels');
  labelWrap.innerHTML = '';
  [0,4,8,12,16,20,23].forEach(h=>{
    const sp = document.createElement('span');
    sp.textContent = `${String(h).padStart(2,'0')}:00`;
    labelWrap.appendChild(sp);
  });
}

